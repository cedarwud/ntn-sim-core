{
  "name": "ntn-sim-core",
  "version": "1.0.0",
  "description": "Research-grade NTN/LEO simulation shell with 3D visualization foundations",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "validate:structure": "node scripts/validate-structure.mjs",
    "validate:trace": "node scripts/validate-traceability-placeholders.mjs",
    "validate:specmode": "node scripts/validate-specmode-gating.mjs",
    "validate:assumption-manifest": "node scripts/validate-assumption-manifest.mjs",
    "validate:profiles": "node scripts/validate-profile-layout.mjs",
    "validate:core-purity": "node scripts/validate-core-purity.mjs",
    "validate:final": "node scripts/validate-final.mjs",
    "validate:runtime": "node scripts/validate-runtime.mjs",
    "validate:orbit-parity": "node --import tsx scripts/validate-orbit-parity.ts",
    "validate:multibeam-gating": "node --import tsx scripts/validate-multibeam-gating.ts",
    "validate:replay-manifest": "node --import tsx scripts/validate-replay-manifest.ts",
    "validate:visual-browser": "node --import tsx scripts/validate-visual-browser.ts",
    "validate:golden-orbit": "node scripts/golden-case-orbit.mjs",
    "validate:golden-channel": "node scripts/golden-case-channel.mjs",
    "validate:golden-engine": "node --import tsx scripts/golden-case-engine.ts",
    "validate:baseline": "node --import tsx scripts/run-baseline.ts",
    "validate:reproduction": "npx tsx scripts/run-reproduction-comparison.ts",
    "validate:audit-profiles": "node --import tsx scripts/audit-profiles.ts",
    "validate:integration": "npm run validate:golden-engine && npm run validate:reproduction",
    "validate:stage": "npm run lint && npm run build && npm run validate:structure && npm run validate:trace && npm run validate:specmode && npm run validate:assumption-manifest && npm run validate:profiles && npm run validate:core-purity && npm run validate:final && npm run validate:runtime && npm run validate:orbit-parity && npm run validate:multibeam-gating && npm run validate:replay-manifest && npm run validate:visual-browser && npm run validate:golden-orbit && npm run validate:golden-channel && npm run validate:golden-engine && npm run validate:audit-profiles"
  },
  "keywords": [
    "3d",
    "research",
    "ntn",
    "leo",
    "satellite",
    "visualization",
    "spatial",
    "interactive"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "satellite.js": "^6.0.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^5.1.0",
    "baseline-browser-mapping": "^2.10.10",
    "playwright-core": "^1.58.2",
    "sass": "^1.93.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
