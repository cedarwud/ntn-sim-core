    },
    "atmospheric_formula_sign": {
      "assumption_id": "ASSUME-MODQN-REP-009",
      "value": {
        "primary_run_formula": "paper-published-sign",
        "primary_expression": "A(d) = 10^(+3 d chi / (10 h))",
        "sign_anomaly_disclosure": "published-sign-yields-gain-for-typical-values",
        "required_sensitivity_formula": "A_corrected(d) = 10^(-3 d chi / (10 h))"
      }
    },
    "evaluation_aggregation": {
      "assumption_id": "ASSUME-MODQN-REP-010",
