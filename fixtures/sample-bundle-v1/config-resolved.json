    "beam_geometry": {
      "assumption_id": "ASSUME-MODQN-REP-002",
      "value": {
        "layout": "hex-7",
        "center_beam": "nadir",
        "ring_beam_count": 6,
        "ring_order": "clockwise",
        "center_to_ring_spacing_rule": "theta_3dB",
